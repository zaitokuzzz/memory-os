APP_NAME=memory-os
APP_ENV=development
APP_PORT=8000

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/memory_os
REDIS_URL=redis://redis:6379/0

EMBEDDING_MODEL=local-stub
EMBEDDING_DIM=1536

DEFAULT_MAX_CONTEXT_TOKENS=1200
DEFAULT_TOP_K=5

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

ARCHIVE_PROVIDER=local
ARCHIVE_BUCKET=memory-archive
ARCHIVE_ENDPOINT=http://localhost:9000
ARCHIVE_ACCESS_KEY=minioadmin
ARCHIVE_SECRET_KEY=minioadmin

LOG_LEVEL=INFO
